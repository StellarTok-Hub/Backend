NODE_ENV=development
PORT=3000

# Postgres (via Prisma)
DATABASE_URL=postgresql://backend:backend@localhost:5432/gateway?schema=public

# Redis (session cache, rate limiting, tip-event pub/sub)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production
# Access tokens are short-lived by design; sessions are carried by the
# rotating, revocable refresh token instead (see REFRESH_TOKEN_TTL_DAYS).
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30

# Deliberately distinct from JWT_SECRET so a leak of one secret doesn't
# compromise both access tokens and OAuth-linking state.
OAUTH_STATE_SECRET=change-me-in-production

# AES-256-GCM key for encrypting TikTok tokens at rest. Generate with:
#   openssl rand -base64 32
ENCRYPTION_KEY=

# TikTok OAuth
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/api/v1/identity/tiktok/callback

# Downstream analytics-service (FastAPI)
ANALYTICS_SERVICE_URL=http://localhost:8000

# Shared secret sent as `X-Service-Auth` on every gateway -> analytics-service
# call. analytics-service has no auth of its own otherwise reachable directly.
SERVICE_AUTH_SECRET=change-me-in-production

# Comma-separated list of origins allowed to make cross-origin browser
# requests, e.g. http://localhost:5173,https://app.example.com
ALLOWED_ORIGINS=http://localhost:5173
