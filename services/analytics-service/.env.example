ENVIRONMENT=development
PORT=8000

# Postgres
DATABASE_URL=postgresql+asyncpg://backend:backend@localhost:5432/analytics

# Redis (tip event pub/sub, published to gateway subscribers)
REDIS_URL=redis://localhost:6379
TIP_EVENTS_CHANNEL=tips:events

# Stellar network
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_WATCHED_ACCOUNT=

LOG_LEVEL=INFO
